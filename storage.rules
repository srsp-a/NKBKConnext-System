rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // รูปจากเว็บองค์กร (ย้ายจาก WordPress)
    match /cms/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    // สลิปแจ้งโอนเงินจากหน้า CMS (อัปโหลดสาธารณะ, อ่านเฉพาะแอดมิน)
    match /cms_payment_slips/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // อัปโหลดผ่าน Admin SDK / Cloud Functions เท่านั้น (migration script ใช้ SA)
  }
}
