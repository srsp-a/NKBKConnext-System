            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "function": "monitorApi"
        }
      ]
    }
  ],
  "emulators": {
    "functions": {
      "port": 5001
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    }
  }
}
