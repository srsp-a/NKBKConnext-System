{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        "monitor-api/node_modules",
        "line-webhook/node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "node scripts/prepare-functions-deploy.js"
      ]
    }
  ],
  "hosting": [
    {
      "target": "main",
      "public": "public-cms",
      "cleanUrls": true,
      "trailingSlash": false,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        },
        {
          "source": "/desktop-app-updates/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            },
            {
              "key": "Access-Control-Allow-Origin",
              "value": "*"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/n/**",
          "function": "cmsOg"
        },
        {
          "source": "/page/**",
          "function": "cmsOg"
        },
        {
          "source": "/news",
          "function": "cmsOg"
        },
        {
          "source": "/download",
          "function": "cmsOg"
        },
        {
          "source": "/about-us",
          "function": "cmsOg"
        },
        {
          "source": "/team",
          "function": "cmsOg"
        },
        {
          "source": "/management",
          "function": "cmsOg"
        },
        {
          "source": "/contact",
          "function": "cmsOg"
        },
        {
          "source": "/infrom-payment",
          "function": "cmsOg"
        },
        {
          "source": "/infrom-payment-line",
          "function": "cmsOg"
        }
      ],
      "redirects": [
        {
          "source": "/page/7934",
          "destination": "/download",
          "type": 301
        },
        {
          "source": "/page/241",
          "destination": "/about-us",
          "type": 301
        },
        {
          "source": "/page/420",
          "destination": "/team",
          "type": 301
        },
        {
          "source": "/page/8929",
          "destination": "/management",
          "type": 301
        },
        {
          "source": "/page/354",
          "destination": "/contact",
          "type": 301
        },
        {
          "source": "/page/9304",
          "destination": "/infrom-payment",
          "type": 301
        },
        {
          "source": "/news.html",
          "destination": "/news",
          "type": 301
        },
        {
          "source": "/index.html",
          "destination": "/",
          "type": 301
        }
      ]
    },
    {
      "target": "monitor",
      "public": "monitor-api/public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/",
          "function": "monitorApi"
        },
        {
          "source": "/api/**",
          "function": "monitorApi"
        },
        {
          "source": "/workstations.html",
          "destination": "/workstations.html"
        }
      ]
    },
    {
      "target": "line",
      "public": "line-api-public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "function": "lineApi"
        }
      ]
    },
    {
      "target": "admin",
      "public": "hosting-dist/admin",
      "ignore": [
        "firebase.json",
